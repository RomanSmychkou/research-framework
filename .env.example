# TODO: очистка legacy параметров конфигурации
COINS_DIR=coins
HISTORICAL_UPLOAD_DIR=coins/_historical_data/spot_pt
SYMBOL_ARTIFACTS_DIR=coins

# =============================================================================
# ClickHouse (local docker-compose defaults)
# =============================================================================
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=crypto_db

# =============================================================================
# Stage 00 — upload_history (*.csv.gz → trades)
# =============================================================================
UPLOAD_CONFIG_NAME=upload_history_config.json
UPLOAD_TABLE=spot_trades

# Rows per native INSERT; halve-and-retry on retriable server errors.
CLICKHOUSE_INSERT_BATCH_ROWS=50000
CLICKHOUSE_CSV_BUFFER_ROWS=1000000
IO_BATCH_SPAN=30d

# TODO: rename в однозначные и понятные названия без привязок
#       к конкретным этапам или процессам
STAGE01_REPLACE_RANGE=false

# =============================================================================
# Stage 02 — exports
# =============================================================================
EXPORT_JSON_NAME=actual_features.json